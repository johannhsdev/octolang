{
    "name": "johannhsdev/laravel-locale-manager",
    "description": "A Laravel package for managing application locales and translations",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "JohannHSDev"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0",
        "illuminate/http": "^11.0|^12.0",
        "illuminate/routing": "^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0",
        "pestphp/pest": "^2.0|^3.0"
    },
    "autoload": {
        "psr-4": {
            "Johannhsdev\\LaravelLocaleManager\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Johannhsdev\\LaravelLocaleManager\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Johannhsdev\\LaravelLocaleManager\\LaravelLocaleManagerServiceProvider"
            ],
            "aliases": {
                "Locale": "Johannhsdev\\LaravelLocaleManager\\Facades\\Locale"
            }
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
