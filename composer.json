{
    "name": "johannhsdev/octolang",
    "description": "A elegant Laravel package for managing application locales — OctoLang",
    "type": "library",
    "license": "MIT",
    "authors": [
        { 
            "name": "Johannhs Dev", 
            "email": "johannsalas96@gmail.com" 
        }
    ],
    "require": {
        "php": "^8.2|^8.4",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "illuminate/http": "^11.0|^12.0|^13.0",
        "illuminate/routing": "^11.0|^12.0|^13.0",
        "illuminate/session": "^11.0|^12.0|^13.0",
        "illuminate/contracts": "^11.0|^12.0|^13.0"
    },
    "suggest": {
        "livewire/livewire": "Required for the OctoLangSwitch Livewire component (^3.0)"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^2.0|^3.0"
    },
    "autoload": {
        "psr-4": {
            "Johannhsdev\\OctoLang\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Johannhsdev\\OctoLang\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Johannhsdev\\OctoLang\\OctoLangServiceProvider"
            ],
            "aliases": {
                "Locale": "Johannhsdev\\OctoLang\\Facades\\Locale"
            }
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
